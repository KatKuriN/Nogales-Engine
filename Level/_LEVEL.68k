	dc.w $190,$A8
	dc.w $198,$A8
	dc.w $158,$B0
	dc.w $160,$B0
	dc.w $168,$B0
	dc.w $170,$B0
	dc.w $180,$B0
	dc.w $188,$B0
	dc.w $190,$B0
	dc.w $198,$B0
	dc.w $158,$B8
	dc.w $160,$B8
	dc.w $168,$B8
	dc.w $170,$B8
