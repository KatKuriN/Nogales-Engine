; ---------------------------------------------------------------------------

DebugArtLoad:
	VDPCMD  move.l,$9E00,VRAM,WRITE,VDPCTRL

	lea     ArtUnc_Text,a0
	move.w  #$9F,d1
	bsr.s   .DebugLoadLoop

	lea     ArtUnc_Text+$220,a0
	move.w  #$16F,d1
	bsr.s   .DebugLoadLoop

	VDPCMD  move.l,$D000,VRAM,WRITE,VDPCTRL

	lea     ArtUnc_Text,a0
	move.w  #$9F,d1
	bsr.s   .DebugLoadLoop

	lea     ArtUnc_Text+$220,a0
	move.w  #$16F,d1

.DebugLoadLoop:
	move.w  (a0)+,VDPDATA
	dbf     d1,.DebugLoadLoop
	rts

; ---------------------------------------------------------------------------

.ColorConv:
	moveq   #0,d0
	move.b  (a0)+,d0
	ror.w   #1,d0
	lsr.b   #3,d0
	rol.w   #1,d0
	move.b  .ColorConvTbl(pc,d0.w),d2
	lsl.w   #8,d2
	moveq   #0,d0
	move.b  (a0)+,d0
	ror.w   #1,d0
	lsr.b   #3,d0
	rol.w   #1,d0
	move.b  .ColorConvTbl(pc,d0.w),d2
	move.w  d2,VDPDATA
	dbf     d1,.DebugLoadLoop ; fractured
	rts

; ---------------------------------------------------------------------------

.ColorConvTbl: 
	dc.b   0
	dc.b   6
	dc.b $60
	dc.b $66

; ---------------------------------------------------------------------------
; Calculate window plane positions for a wavy effect in HBLANK
; ---------------------------------------------------------------------------

CalcWaterWaves:
	lea     globalBuffer.w,a0
	move.w  waterCnt.w,d2
	move.w  #$9100,d3       ; Set window plane register
	move.w  #256-1,d7

.Loop:
	move.w  d2,d0
	bsr.w   CalcSinCos
	asr.w   #4,d0
	bpl.s   .SkipNegative  ; Filter negative values
	moveq   #0,d0

.SkipNegative:
	andi.w  #$1F,d0
	move.b  d0,d3
	move.w  d3,(a0)+
	addq.w  #2,d2
	dbf     d7,.Loop
	addq.w  #2,waterCnt.w
	rts


; ---------------------------------------------------------------------------
; Set Water Line for HBLANK firing
; This is horribly hacky, but I really can't be bothered right now.
; ---------------------------------------------------------------------------


SetHblankLine:
	move.w  cameraZPosY.w,d0
	cmpi.w  #-16,d0
	bhi.s   .DoZ
	cmpi.b  #224-1,hblankLine+1.w
	beq.s   .Exit
.DoZ:
	neg.w   d0
	subi.b  #48+1,d0
	cmpi.b  #222,d0
	bhs.s   .Exit
	move.b  d0,hblankLine+1.w
	rts
.Exit:
	move.b  #224-1,hblankLine+1.w
	rts