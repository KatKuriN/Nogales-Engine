


GM_LEVEL:                               
	bsr.w   ClearArtListQueue
	moveq   #0,d0
	move.b  zone.w,d0
	lsl.w   #4,d0
	lea     LevelHeaders,a2
	lea     (a2,d0.w),a2
	moveq   #0,d0
	move.b  (a2),d0
	bsr.w   LoadArtList                     
	moveq   #1,d0
	bsr.w   LoadArtList
	bsr.w   PalFadeOut
	bsr.w   InitScreen
	lea     VDPCTRL,a6
	move.w  #$8B03,(a6)
	move.w  #$8230,(a6)
	move.w  #$8407,(a6)
	move.w  #$857C,(a6)
	move.w  #0,hblankWaterFlag.w
	move.w  #$8AAF,hblankLine.w
	move.w  #$8004,(a6)
	move.w  #$8720,(a6)
	lea     OBJECTRAM.w,a1
	moveq   #0,d0
	move.w  #((OBJSZ*20)/4)-1,d1

.ClearObjects:                         
	move.l  d0,(a1)+
	dbf     d1,.ClearObjects
	lea     cameraAPosX.w,a1
	moveq   #0,d0
	move.w  #$40-1,d1

.ClearCams:                            
	move.l  d0,(a1)+
	dbf     d1,.ClearCams
	moveq   #3,d0
	bsr.w   PalLoad
	moveq   #0,d0
	move.b  zone.w,d0

.WaitUntilDone:                        
	move.b  #vbID_LVLSTART,vblankCmd.w
	bsr.w   VSync
	bsr.w   GetObjects
	bsr.w   RunObjects
	bsr.w   DrawObjects
	bsr.w   ProcessArtLoading
	tst.l   decompQueue.w
	bne.s   .WaitUntilDone
	moveq   #3,d0
	bsr.w   PalQueueForFade
	bsr.w   CameraInit
	bsr.w   CameraScroll
	bsr.w   ProcessLevelHeader
	bsr.w   DrawCamsInit
	
	; this is really gross lol

	move.l  #LvlCol_GreenHill,collisionPtr.w
	cmpi.b  #ZONENO.LZ,zone.w
	bne.s   .ChkMarble
	move.l  #LvlCol_Labyrinth,collisionPtr.w

.ChkMarble:
	cmpi.b  #ZONENO.MZ,zone.w
	bne.s   .ChkStarLight
	move.l  #LvlCol_Marble,collisionPtr.w

.ChkStarLight:
	cmpi.b  #ZONENO.SLZ,zone.w
	bne.s   .ChkSparkling
	move.l  #LvlCol_StarLight,collisionPtr.w

.ChkSparkling:
	cmpi.b  #ZONENO.SZ,zone.w
	bne.s   .ChkClockWork
	move.l  #LvlCol_Sparkling,collisionPtr.w

.ChkClockWork:
	cmpi.b  #ZONENO.CWZ,zone.w
	bne.s   .NoCollision
	move.l  #LvlCol_Clockwork,collisionPtr.w

.NoCollision:
	move.b  #OBJNO_PLAYER,objSlot00.w    
;	move.b  #$21,(objSlot01).w
	btst    #6,joypad.w
	beq.s   .NoDebug
	move.b  #1,debug.w
	bsr.w   DebugSetup
.NoDebug:
	move.w  #0,joypadMirr.w
	move.w  #0,joypad.w
	move.w  #1800,genericTimer.w
	move.b  #vbID_LEVEL,vblankCmd.w
	bsr.w   VSync

	move.w  #$202F,palFadeArgs.w
	bsr.w   PalFadeIn.UserArgs
	move.w  #$8000+%00010100,VDPCTRL
	bsr.w   DebugArtLoad

LevelLoop:                              
	bsr.w   PauseGame
	move.b  #vbID_LEVEL,vblankCmd.w
	bsr.w   VSync
	addq.w  #1,frameCnt.w
	move.w  joypad.w,joypadMirr.w

	bsr.w   GetObjects
	bsr.w   RunObjects                        
	bsr.w   CameraScroll
	bsr.w   SetHblankLine
	bsr.w   CalcWaterWaves
	bsr.w   DrawObjects
	bsr.w   CyclePalettes
	bsr.w   ProcessArtLoading

	tst.w   restart.w
	bne.w   GM_LEVEL

	cmpi.b  #GMNO_LEVEL,gamemode.w
	beq.w   LevelLoop
	rts 

; ---------------------------------------------------------------------------
; Setup Debugger onscreen digits
; ---------------------------------------------------------------------------

DebugSetup:
	lea     DebugDigits,a0
	lea     objSlot10.w,a1
	move.w  #12-1,d1

.LoadLoop:                             
	move.b  #OBJNO_DIGIT1,obj.No(a1)
	move.w  (a0)+,obj.X(a1)
	move.w  (a0)+,obj.YScr(a1)
	lea     OBJSZ(a1),a1
	dbf     d1,.LoadLoop
	rts

; ---------------------------------------------------------------------------

DebugDigits: 
	dc.w $158,$90
	dc.w $160,$90
	dc.w $168,$90
	dc.w $170,$90 

	dc.w $158,$98
	dc.w $160,$98
	dc.w $168,$98
	dc.w $170,$98

	dc.w $158,$A8
	dc.w $160,$A8
	dc.w $168,$A8
	dc.w $170,$A8

; ---------------------------------------------------------------------------
; Setup Debugger onscreen digits (Older Null Variant)
; ---------------------------------------------------------------------------

DebugSetupOld:
	lea     DebugDigitsOld,a0
	lea     objSlot0A.w,a1
	move.w  #51,d1

.LoadLoop:                             
	move.b  #OBJNO_DIGIT1,(a1)
	move.w  (a0)+,obj.X(a1)
	move.w  (a0)+,obj.YScr(a1)
	lea     OBJSZ(a1),a1
	dbf     d1,.LoadLoop
	rts

; ---------------------------------------------------------------------------

