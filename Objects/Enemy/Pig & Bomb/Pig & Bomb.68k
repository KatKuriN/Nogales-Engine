; ---------------------------------------------------------------------------
; Unused Enemy Pig and the bomb it launches
; These are not the same objects as the final game. They were later redone.
;
; This variant was seen in B-Roll footage used in Computer Chronicles
; ---------------------------------------------------------------------------

; ---------------------------------------------------------------------------
; Enemy Pig object code
; ---------------------------------------------------------------------------
; local enums

pig.Timer	= $30
pig.Flag	= $32
; ---------------------------------------------------------------------------

ObjEnemyPig:
	moveq	#0,d0
	move.b	obj.Action(a0),d0
	move.w	.Index(pc,d0.w),d1
	jmp	.Index(pc,d1.w)

; ---------------------------------------------------------------------------
.Index:
	dc.w	Pig_Init-.Index
	dc.w	Pig_Main-.Index
	dc.w	Pig_Show-.Index
	dc.w	Pig_Done-.Index
; ---------------------------------------------------------------------------

Pig_Init:
	move.b	#19,obj.YRad(a0)
	move.b	#8,obj.XRad(a0)
	move.l	#SprPat_Pig,obj.Pat(a0)
	move.w	#$2400,obj.Tile(a0)
	move.b	#4,obj.Render(a0)
	move.b	#4,obj.Priority(a0)
	move.b	#5,obj.Collision(a0)
	move.b	#12,obj.XRender(a0)

	; For some reason, it falls to the floor first
	; This ends up looping the above init. code
	; Probably done to adjust for collision scope
	; However, it doesn't set to draw

	bsr.w	_objectFall		; Apply gravity and speed

	jsr	_physBasicChkDown	; Check collision down
	tst.w	d1
	bpl.s	.OverFloor		; If over floor, exit

	add.w	d1,obj.Y(a0)		; Adhere to floor
	move.w	#0,obj.YSpeed(a0)	; Clear falling YSpeed
	addq.b	#2,obj.Action(a0)	; Increment action cntr.

.OverFloor:
	rts

; -----------------------------------------------------
; Main loop
; -----------------------------------------------------

Pig_Main:
	moveq	#0,d0
	move.b	obj.SubAction(a0),d0
	move.w	.Subdex(pc,d0.w),d1
	jsr	.Subdex(pc,d1.w)
	lea	AniSpr_Pig,a1
	bsr.w   _objectAnimate
	bra.w	_objectDraw

; ---------------------------------------------------------------------------
.Subdex:
	dc.w	PigSub_Walk-.Subdex
	dc.w	PigSub_Idle-.Subdex
; ---------------------------------------------------------------------------

; -----------------------------------------------------
; Walk to left or right and fire
; -----------------------------------------------------

PigSub_Walk:
	subq.w	#1,pig.Timer(a0)
	bpl.s	.WaitTimer

	addq.b	#2,obj.SubAction(a0)	; Increment action
	move.w	#$FF,pig.Timer(a0)	; Set timer
	move.w	#$40,obj.XSpeed(a0)	; Set base XSpeed
	move.b	#1,obj.Anim(a0)		; Set anim

	bchg	#0,obj.Status(a0)	; Change orientation stat.
	bne.s	.XFlip			; Skip if XFlip set

	neg.w	obj.XSpeed(a0)		; Flip movement direction if not

.XFlip:
	move.b	#0,pig.Flag(a0)		; Clear firing flag
	rts

; -----------------------------------------------------

.WaitTimer:
	tst.b	pig.Flag(a0)		; Has bomb launched already?
	bne.s	.FlagSet

	cmpi.b	#2,obj.Frame(a0)	; If on launch frame, create bomb obj.
	beq.s	.LaunchBomb

.FlagSet:
	rts

.LaunchBomb:
	move.b	#1,pig.Flag(a0)			; Set as launched already

	bsr.w	_objectFindFreeSlot		; Find object slot
	bne.s	.NotFound

	move.b	#OBJNO_BALLBOMB,obj.No(a1)	; Set object info
	move.w	obj.X(a0),obj.X(a1)
	move.w	obj.Y(a0),obj.Y(a1)
	addi.w	#16,obj.Y(a1)			; Adjust down a bit

.NotFound:
	rts

; -----------------------------------------------------
; Wait a little bit before continuing to walk
; -----------------------------------------------------

PigSub_Idle:
	subq.w	#1,pig.Timer(a0)
	bmi.s	.TimerDepl

	bsr.w	_objectSetSpeed
	jsr	_physBasicChkDown
	add.w	d1,obj.Y(a0)
	rts

.TimerDepl:
	subq.b	#2,obj.SubAction(a0)
	move.w	#59,pig.Timer(a0)
	move.w	#0,obj.XSpeed(a0)
	move.b	#0,obj.Anim(a0)
	tst.b	obj.Render(a0)
	bpl.s	.Return
	move.b	#2,obj.Anim(a0)

.Return:
	rts

; -----------------------------------------------------
; Display (unused)
; -----------------------------------------------------
Pig_Show:
	bsr.w	_objectDraw
	rts

; -----------------------------------------------------
; Delete (unused)
; -----------------------------------------------------
Pig_Done:
	bsr.w	_objectDelete
	rts



; ---------------------------------------------------------------------------
; Bomb launched by Enemy Pig
; ---------------------------------------------------------------------------
; local enums

ballbomb.Timer	= $30

; ---------------------------------------------------------------------------

ObjBallBomb:
	moveq	#0,d0
	move.b	obj.Action(a0),d0
	move.w	.Index(pc,d0.w),d1
	jmp	.Index(pc,d1.w)

; ---------------------------------------------------------------------------
.Index:
	dc.w	BallBomb_Init-.Index
	dc.w	BallBomb_Main-.Index
	dc.w	BallBomb_Done-.Index
; ---------------------------------------------------------------------------

BallBomb_Init:
	addq.b	#2,obj.Action(a0)
	move.l	#SprPat_BallBomb,obj.Pat(a0)
	move.w	#$2418,obj.Tile(a0)
	move.b	#4,obj.Render(a0)
	move.b	#3,obj.Priority(a0)
	move.b	#$87,obj.Collision(a0)
	move.b	#8,obj.XRender(a0)		; X render width
	move.w	#24,ballbomb.Timer(a0)		; Set initial timer value

BallBomb_Main:
	btst	#STAT.KILLED,obj.Status(a0)	; Check if kill flag set
	bne.s	.Explode			; If so, explode
	tst.w	ballbomb.Timer(a0)
	bne.s	.WaitToCol			; Wait a bit before colliding

	jsr	_physBasicChkDown		; Check if hitting floor
	tst.w	d1
	bpl.s	.NoFloorFound
	add.w	d1,obj.Y(a0)

.Explode:
	move.b	#OBJNO_BOMBHIT,obj.No(a0)	; Set obj.No to explosion code
	move.b	#0,obj.Action(a0)		; Clear action counter
	bra.w	ObjBombHit			; Run initialization for it


.WaitToCol:
	subq.w	#1,ballbomb.Timer(a0)

.NoFloorFound:
	bsr.w	_objectFall
	bsr.w	_objectDraw
	move.w	limitADown.w,d0
	addi.w	#$E0,d0
	cmp.w	obj.Y(a0),d0
	bcs.s	BallBomb_Done
	rts

; -----------------------------------------------------
; Delete
; -----------------------------------------------------
BallBomb_Done:
	bsr.w	_objectDelete
	rts

; ---------------------------------------------------------------------------
; Bomb/Missile Explosion
; ---------------------------------------------------------------------------

ObjBombHit:
	moveq	#0,d0
	move.b	obj.Action(a0),d0
	move.w	.Index(pc,d0.w),d1
	jmp	.Index(pc,d1.w)
; ---------------------------------------------------------------------------
.Index:
	dc.w	BombHit_Init-.Index
	dc.w	BombHit_Main-.Index
; ---------------------------------------------------------------------------

BombHit_Init:
	addq.b	#2,obj.Action(a0)
	move.l	#SprPat_BombHit,obj.Pat(a0)
	move.w	#$41C,obj.Tile(a0)
	move.b	#4,obj.Render(a0)
	move.b	#2,obj.Priority(a0)
	move.b	#0,obj.Collision(a0)
	move.b	#$C,obj.XRender(a0)
	move.b	#9,obj.FrameTimer(a0)
	move.b	#0,obj.Frame(a0)
	move.w	#SFXNO_BOMBHIT,d0
	jsr	SndSetSFX

BombHit_Main:
	subq.b	#1,obj.FrameTimer(a0)
	bpl.s	.Exit
	move.b	#9,obj.FrameTimer(a0)
	addq.b	#1,obj.Frame(a0)
	cmpi.b	#4,obj.Frame(a0)
	beq.w 	_objectDelete

.Exit:
	bra.w   _objectDraw

; ---------------------------------------------------------------------------
; Light explosion, used for items and exploding enemies
; ---------------------------------------------------------------------------

ObjLightExpl:
	moveq	#0,d0
	move.b	obj.Action(a0),d0
	move.w	.Index(pc,d0.w),d1
	jmp	.Index(pc,d1.w)
; ---------------------------------------------------------------------------
.Index:
	dc.w	LightExplosion_Init-.Index
	dc.w	LightExplosion_Main-.Index
	dc.w	_explosionsAnimate-.Index
; ---------------------------------------------------------------------------

LightExplosion_Init:
	addq.b	#2,obj.Action(a0)
	bsr.w	_objectFindFreeSlot
	bne.s	LightExplosion_Main
	move.b	#$28,obj.No(a1)
	move.w	obj.X(a0),obj.X(a1)
	move.w	obj.Y(a0),obj.Y(a1)

LightExplosion_Main:
	addq.b	#2,obj.Action(a0)
	move.l	#MapSpr_LightExplosion,obj.Pat(a0)
	move.w	#$5A0,obj.Tile(a0)
	move.b	#4,obj.Render(a0)
	move.b	#2,obj.Priority(a0)
	move.b	#0,obj.Collision(a0)
	move.b	#$C,obj.XRender(a0)
	move.b	#7,obj.FrameTimer(a0)
	move.b	#0,obj.Frame(a0)
	move.w	#SFXNO_POP2,d0
	jsr	SndSetSFX.l

_explosionsAnimate:
	subq.b	#1,obj.FrameTimer(a0)
	bpl.s	.Exit
	move.b	#7,obj.FrameTimer(a0)
	addq.b	#1,obj.Frame(a0)
	cmpi.b	#5,obj.Frame(a0)
	beq.w	_objectDelete

.Exit:
	bra.w	_objectDraw


; ---------------------------------------------------------------------------
; Heavy red/orange explosion, like the mobile bomb enemy or boss explosions
; ---------------------------------------------------------------------------

ObjHeavyExpl:
	moveq	#0,d0
	move.b	obj.Action(a0),d0
	move.w	.Index(pc,d0.w),d1
	jmp	.Index(pc,d1.w)
; ---------------------------------------------------------------------------
.Index:
	dc.w	HeavyExplosion_Init-.Index
	dc.w	_explosionsAnimate-.Index
; ---------------------------------------------------------------------------

HeavyExplosion_Init:
	addq.b	#2,obj.Action(a0)
	move.l	#MapSpr_HeavyExplosion,obj.Pat(a0)
	move.w	#$5A0,obj.Tile(a0)
	move.b	#4,obj.Render(a0)
	move.b	#2,obj.Priority(a0)
	move.b	#0,obj.Collision(a0)
	move.b	#$C,obj.XRender(a0)
	move.b	#7,obj.FrameTimer(a0)
	move.b	#0,obj.Frame(a0)
	move.w	#$C4,d0
	jmp	SndSetSFX.l


AniSpr_Pig:
	include "Objects/Enemy/Pig & Bomb/PIG_ANI.asm"
SprPat_Pig:
	include "Objects/Enemy/Pig & Bomb/PIG_PAT.asm"
SprPat_BallBomb:
	include "Objects/Enemy/Pig & Bomb/BALLBOMB_PAT.asm"
SprPat_BombHit:
	include "Objects/Enemy/Pig & Bomb/BOMBHIT_PAT.asm"


MapSpr_LightExplosion:
		dc.w lexplosp0-MapSpr_LightExplosion
		dc.w lexplosp1-MapSpr_LightExplosion
		dc.w lexplosp2-MapSpr_LightExplosion
		dc.w lexplosp3-MapSpr_LightExplosion
		dc.w lexplosp4-MapSpr_LightExplosion
lexplosp0:	dc.b   1, -8,  9,  0,  0,-$C
lexplosp1:	dc.b   1,-$10, $F,  0,  6,-$10
lexplosp2:	dc.b   1,-$10, $F,  0,$16,-$10
lexplosp3:	dc.b   4,-$14, $A,  0,$26,-$14,-$14,  5
		dc.b   0,$2F,  4,  4,  5,$18,$2F,-$14
		dc.b  -4, $A,$18,$26, -4
lexplosp4:	dc.b   4,-$14, $A,  0,$33,-$14,-$14,  5
		dc.b   0,$3C,  4,  4,  5,$18,$3C,-$14
		dc.b  -4, $A,$18,$33, -4
MapSpr_HeavyExplosion:
		dc.w lexplosp0-MapSpr_HeavyExplosion
		dc.w hexplosp1-MapSpr_HeavyExplosion
		dc.w hexplosp2-MapSpr_HeavyExplosion
		dc.w lexplosp3-MapSpr_HeavyExplosion
		dc.w lexplosp4-MapSpr_HeavyExplosion
hexplosp1:	dc.b   1,-$10, $F,  0,$40,-$10
hexplosp2:	dc.b   1,-$10, $F,  0,$50,-$10